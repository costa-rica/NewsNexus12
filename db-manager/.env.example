# NewsNexus12 Database Manager Environment Configuration

# Application Environment
# Valid values: development, testing, production
NODE_ENV=development

# Application Name (used for log file naming)
NAME_APP=NewsNexus12DbManager

# Logging Configuration
# Absolute path to logs directory
PATH_TO_LOGS=/absolute/path/to/logs

# Maximum log file size in MB (default: 5)
LOG_MAX_SIZE=5

# Maximum number of rotated log files (default: 5)
LOG_MAX_FILES=5

# Database Configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=newsnexus_dev
PG_USER=postgres
PG_PASSWORD=
PG_SCHEMA=public

# Optional: runtime app role to re-grant after schema rebuild.
# When set, rebuildSchema() (used by --zip_file) will run GRANT statements
# so the app role can see tables after a replenish without a manual SQL step.
# Set this to the role name used by api / worker-node / worker-python.
# Leave blank if the same role is used for both bootstrap and runtime.
PG_APP_ROLE=

# Backup Configuration
# Absolute path to backup directory (required for --create_backup)
PATH_DB_BACKUPS=/absolute/path/to/backups
