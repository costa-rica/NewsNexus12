# NewsNexus12 Database Manager Environment Configuration

# Application Environment
# Valid values: development, testing, production
NODE_ENV=development

# Application Name (used for log file naming)
NAME_APP=NewsNexus12DbManager

# Logging Configuration
# Absolute path to logs directory
PATH_TO_LOGS=/absolute/path/to/logs

# Maximum log file size in MB (default: 5)
LOG_MAX_SIZE=5

# Maximum number of rotated log files (default: 5)
LOG_MAX_FILES=5

# Database Configuration
# Absolute path to database directory
PATH_DATABASE=/absolute/path/to/database

# Database filename (e.g., newsnexus12.db)
NAME_DB=newsnexus12.db

# Backup Configuration
# Absolute path to backup directory (required for --create_backup)
PATH_DB_BACKUPS=/absolute/path/to/backups
